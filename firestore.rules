rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A signed-in user may read and write only their own data subtree.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public, per-game leaderboards. Any signed-in user may read; a user may
    // only create/update their OWN entry (doc id == uid) and never delete.
    match /leaderboards/{gameId}/entries/{entryUid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == entryUid
        && request.resource.data.uid == entryUid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.name is string;
      allow delete: if false;
    }

    // Live multiplayer games ("Squad Clash"). Any signed-in user may read a game
    // (to join/play). Only the host may create and advance the game doc; each
    // player may only create/update their OWN player row.
    match /games/{pin} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.pin == pin;
      allow update: if request.auth != null
        && resource.data.hostUid == request.auth.uid;
      allow delete: if false;

      match /players/{playerUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == playerUid
          && request.resource.data.uid == playerUid;
        allow delete: if false;
      }
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
