rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A signed-in user may read and write only their own data subtree.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public, per-game leaderboards. Any signed-in user may read; a user may
    // only create/update their OWN entry (doc id == uid) and never delete.
    match /leaderboards/{gameId}/entries/{entryUid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == entryUid
        && request.resource.data.uid == entryUid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.name is string;
      allow delete: if false;
    }

    // Squads (class/group rooms). Any signed-in user may read squad metadata and
    // join (write their OWN member doc). The squad doc itself is create-only by
    // its owner and never edited/deleted, so a code can't be hijacked.
    match /squads/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.name is string;
      allow update, delete: if false;

      // Membership: a user may only create/remove their own membership row.
      match /members/{memberUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == memberUid
          && request.resource.data.uid == memberUid;
        allow delete: if request.auth != null && request.auth.uid == memberUid;
      }

      // Daily-question board: readable by any member; a user may only write their
      // own entry (doc id == uid) and never delete it.
      match /dailyBoards/{date}/entries/{entryUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == entryUid
          && request.resource.data.uid == entryUid
          && request.resource.data.score is number
          && request.resource.data.correct is bool
          && request.resource.data.timeMs is number;
        allow delete: if false;
      }
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
