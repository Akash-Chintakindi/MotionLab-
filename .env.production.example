# Copy this file to `.env.production` and fill in your real Firebase web config.
# Vite loads `.env.production` automatically during `npm run build`, and these
# values override `.env`, so the production bundle talks to live Firebase.
#
# Find these values in: Firebase Console -> Project settings -> General ->
# "Your apps" -> SDK setup and configuration -> Config.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Must be false in production so the app uses live Firebase, not the emulators.
VITE_USE_FIREBASE_EMULATORS=false
